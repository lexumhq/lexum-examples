domain NamespaceTask {
  scope { domain }
  capability { messaging, send_to:NamespaceTask }

  state {
    status: string
  }

  goal Completed {
    target status == "done"
  }

  transition Execute {
    capability { messaging, send_to:NamespaceTask }
    slice step {
      send("NamespaceTask", "RunScopedAction")
    }
  }
}
